{
  "name": "graphdl-orm",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build:wasm": "cd crates/fol-engine && wasm-pack build --target web --out-dir pkg",
    "build:wasm:test": "cd crates/fol-engine && cargo test",
    "build": "yarn build:wasm",
    "dev": "wrangler dev",
    "deploy": "yarn build && wrangler deploy",
    "test": "vitest run",
    "test:all": "yarn build:wasm:test && vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "itty-router": "^5.0.22"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250124.0",
    "tsx": "^4.0.0",
    "typescript": "^5.7.2",
    "vitest": "^4.0.18",
    "wrangler": "^4.77.0"
  }
}
