{
  "name": "graphdl-orm",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "graphdl": "./src/cli/import.ts",
    "graphdl-mcp": "./src/mcp/server.ts"
  },
  "scripts": {
    "mcp": "tsx src/mcp/server.ts",
    "import": "tsx src/cli/import.ts",
    "build:wasm": "cd crates/arest && wasm-pack build --target web --out-dir pkg --features cloudflare && cd ../.. && node scripts/sanitize-wasm-dts.mjs",
    "build:wasm:test": "cd crates/arest && cargo test",
    "build": "yarn build:wasm",
    "dev": "wrangler dev",
    "deploy": "yarn build && wrangler deploy",
    "test": "vitest run",
    "test:all": "yarn build:wasm:test && vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "itty-router": "^5.0.22"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250124.0",
    "@types/node": "^25.5.2",
    "tsx": "^4.0.0",
    "typescript": "^5.7.2",
    "vitest": "^4.0.18",
    "wrangler": "^4.77.0"
  }
}
