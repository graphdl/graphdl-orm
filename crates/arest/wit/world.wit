/// AREST: Applicative REpresentational State Transfer
///
/// SYSTEM:x = <o, D'>
/// One function. Readings in, applications out.

package arest:engine@0.1.0;

interface types {
    record binding {
        noun: string,
        value: string,
    }
}

/// The AREST engine. One system function.
interface engine {
    use types.{binding};

    /// compile compose parse. Readings in, handle out.
    parse-and-compile: func(readings: list<tuple<string, string>>) -> result<u32, string>;

    /// Release a compiled domain handle.
    release: func(handle: u32);

    /// The system function. SYSTEM:x = <o, d>.
    /// One entry point. Input classification inside.
    system: func(handle: u32, key: string, input: string) -> string;
}

world arest {
    export engine;
}
