// crates/arest-kernel/ui/apps/UnifiedRepl.slint
//
// AREST kernel — Unified REPL panel (#510, EPIC #496).
//
// Foundational structural merge of HateoasBrowser (Track SSS #429)
// and Repl (Track TTT #430) into a single Slint surface. The
// motivation, per the user's vision in #496:
//
//   "the repl should be easy to use. It should render the system as
//    the current screen of an app so that the user is never lost. It
//    provides SYSTEM calls, but it should be easy to navigate the
//    system using its own principles"
//
// THIS commit lands ONLY the structural merge: a two-pane layout that
// co-locates today's HATEOAS resource browser (left) and today's REPL
// scrollback + prompt (right) in one Window. The follow-up sub-tasks
// (#511 cell-as-screen, #512 navigation actions, #513 SYSTEM-as-actions,
// etc.) layer the cross-pane behaviours on top.
//
// # Layout
//
//   * Top bar: title + theme toggle (mirrors the prior single-app
//     surfaces — same neutral-100 background, type-h2 wordmark, ghost
//     theme button).
//   * Body: HorizontalLayout of two panes.
//       - Left pane (HATEOAS browse, ~520px): three sub-columns
//         (Resources sidebar, Instances list, Detail panel) — same
//         shape HateoasBrowser.slint shipped.
//       - Right pane (REPL, fills remaining width): scrollback Card
//         on top, prompt + TextInput row at the bottom — same shape
//         Repl.slint shipped.
//   * Status footer: Combined view (resource count + scrollback line
//     count + brief navigation hint).
//
// # Multi-entry pattern
//
// This file is the new slint-build COMPILE ENTRY (build.rs L222 area
// + Dockerfile.uefi L54 area). It re-exports every Window-derived
// component the kernel ships (AppLauncher, Doom, Keyboard) so the
// slint compiler walks the import graph and emits all Window types
// into one generated `UnifiedRepl.rs` reached by
// `slint::include_modules!()` in `arch/uefi/slint_backend.rs`. The
// previously-separate HateoasBrowser + Repl files are deleted in this
// commit; only `UnifiedRepl` here exposes both their callback
// surfaces (now unified on a single component).

import { AppShell, Theme, ThemeMode } from "../AppShell.slint";
import { Button, ButtonVariant } from "../components/Button.slint";
import { Card } from "../components/Card.slint";
import { List, ListItem } from "../components/List.slint";
// Re-exported launcher app surfaces. The slint compiler walks these
// imports and emits each Window-derived component into the single
// generated `UnifiedRepl.rs`. The launcher (Track UUU #431) instantiates
// these by name from `crate::arch::uefi::slint_backend::*`.
import { AppLauncher } from "./AppLauncher.slint";
import { Doom } from "./Doom.slint";
import { Keyboard } from "./Keyboard.slint";

// Re-export AppShell + Theme + the launcher apps so existing callsites
// (slint_backend.rs's smoke test for AppShell, and `crate::ui_apps::
// {launcher,doom,keyboard}` for the three side apps) keep compiling
// without touching the generated symbol path.
export { AppShell, Theme, ThemeMode, AppLauncher, Doom, Keyboard }

export component UnifiedRepl inherits Window {
    // ---- HATEOAS-side inputs (left pane, mirrors HateoasBrowser) ----

    // Sidebar: every Noun the metamodel knows about (sorted).
    in property <[string]> resources;
    // Index of the selected Noun in `resources`. -1 = nothing picked.
    in property <int> selected-resource-index: -1;

    // Instance list for the selected Noun.
    in property <[string]> instances;
    in property <int> selected-instance-index: -1;

    // Detail panel: each line is one binding (`role = value`) or one
    // back-reference. Rust glue formats; Slint just renders.
    in property <[string]> detail-lines;

    // Breadcrumbs across the top of the left pane.
    in property <[string]> breadcrumbs;

    // ---- REPL-side inputs (right pane, mirrors Repl) ----------------

    // Scrollback: each entry is one rendered line of REPL output. The
    // Rust glue caps the model at ~1000 entries (oldest dropped).
    in property <[string]> scrollback;

    // Prompt prefix shown at the start of the input row.
    in property <string> prompt: "arest> ";

    // Two-way binding to the live TextInput contents. Up/Down (history
    // walk) updates this from Rust; user keystrokes update from Slint.
    in-out property <string> current-input;

    // ---- Cell-as-screen typed surface (#511, EPIC #496) -------------
    //
    // Every screen IS a cell. The Rust glue tracks one
    // `CurrentCell` (Root / Noun / Instance / FactCell /
    // ComponentInstance) and runs it through the Component selection
    // rules (#492 via the kernel-internal `cell_renderer`). What
    // lands here on every redraw:
    //
    //   * `current-cell-name`      — display label for the cell
    //     (e.g. "Resources", "File/f1", "Component_has_Property").
    //   * `current-cell-component` — selected Component role
    //     (e.g. "list", "card"). Empty string when no Component matched.
    //   * `current-cell-toolkit`   — selected toolkit slug
    //     (e.g. "slint"). Empty when no Component matched.
    //   * `current-cell-symbol`    — toolkit-side symbol
    //     (e.g. "List", "Card"). Empty when no Component matched.
    //   * `current-cell-fields`    — projected cell data, one line
    //     per field. Always populated (transparency: even when a
    //     specialised Component is shown, the user sees the data
    //     driving it).
    //
    // The Slint side renders these as a labelled card on top of the
    // scrollback in the right pane. The card is the typed surface;
    // future commits (#512+ navigation actions, #515 command palette)
    // attach interactivity to its rows. This commit lands the
    // dispatch + render path; no row-level click handling yet.
    in property <string> current-cell-name: "Resources";
    in property <string> current-cell-component;
    in property <string> current-cell-toolkit;
    in property <string> current-cell-symbol;
    in property <[string]> current-cell-fields;

    // ---- Navigation actions as cells (#512, EPIC #496) -------------
    //
    // HATEOAS via the cell graph itself: every screen exposes a list
    // of "navigate to X" affordances derived from the FT graph (roles
    // → joinable cells, derivations → consumed/produced cells, SM →
    // next-state hop). The Rust glue computes the list via
    // `cell_renderer::render_current_cell` (which delegates to
    // `navigation::compute_navigation_targets`) and sends one row per
    // target through this property.
    //
    // Each entry is a pre-formatted label (e.g. "[role] File",
    // "[instance] File/f1"). Clicks fire `navigation-target-selected`
    // with the row index — the kernel side resolves the index into a
    // `CurrentCell` jump via its cached navigation-target vector.
    in property <[string]> navigation-targets;

    // ---- Combined status text --------------------------------------

    // Footer status text — Rust glue renders a combined summary.
    in property <string> status-text: "Ready";

    // ---- HATEOAS-side callbacks ------------------------------------

    // Sidebar row clicked. Argument is the index into `resources`.
    callback resource-selected(int);
    // Instance row clicked. Argument is the index into `instances`.
    callback instance-selected(int);
    // Back button on the breadcrumb bar.
    callback back-clicked();

    // ---- REPL-side callbacks ---------------------------------------

    // Enter pressed in the input row. Argument is the just-submitted
    // line. Rust glue echoes prompt+line, evaluates, pushes response,
    // updates history, and clears `current-input`.
    callback submit(string);
    // Ctrl+L pressed in the input row. Rust clears scrollback.
    callback clear();
    // Up arrow — walk one step into the past.
    callback history-prev();
    // Down arrow — walk one step toward the present.
    callback history-next();
    // Navigation affordance row clicked (#512). Argument is the
    // index into `navigation-targets`. Kernel resolves the index via
    // its cached navigation-target vector and updates `current-cell`.
    callback navigation-target-selected(int);

    // ---- Window chrome ----------------------------------------------

    // Theme toggle from the top bar.
    callback theme-toggled();

    title: "AREST — Unified REPL";
    background: Theme.surface;
    default-font-family: Theme.type-body.family;
    default-font-size: Theme.type-body.size;
    preferred-width: 1280px;
    preferred-height: 800px;
    forward-focus: input;

    VerticalLayout {
        spacing: 0px;

        // ----- Top bar: breadcrumbs + back + theme toggle -----------
        Rectangle {
            background: Theme.neutral-100;
            min-height: 56px;

            HorizontalLayout {
                padding-left: Theme.spacing-lg;
                padding-right: Theme.spacing-lg;
                padding-top: Theme.spacing-md;
                padding-bottom: Theme.spacing-md;
                spacing: Theme.spacing-md;
                alignment: space-between;

                HorizontalLayout {
                    spacing: Theme.spacing-sm;
                    alignment: start;

                    Button {
                        text: "Back";
                        variant: ButtonVariant.ghost;
                        enabled: root.breadcrumbs.length > 1;
                        clicked => { root.back-clicked(); }
                    }

                    Text {
                        text: "REPL";
                        color: Theme.text-primary;
                        font-family: Theme.type-h2.family;
                        font-weight: Theme.type-h2.weight;
                        font-size: Theme.type-h2.size;
                        vertical-alignment: center;
                    }

                    for crumb[idx] in root.breadcrumbs : Text {
                        text: idx == 0 ? "  " + crumb : " / " + crumb;
                        color: idx == root.breadcrumbs.length - 1
                            ? Theme.text-primary
                            : Theme.text-muted;
                        font-family: Theme.type-h3.family;
                        font-weight: idx == root.breadcrumbs.length - 1
                            ? Theme.type-h3.weight
                            : 400;
                        font-size: Theme.type-h3.size;
                        vertical-alignment: center;
                    }
                }

                Button {
                    text: Theme.mode == ThemeMode.dark ? "Light" : "Dark";
                    variant: ButtonVariant.ghost;
                    clicked => {
                        Theme.toggle-mode();
                        root.theme-toggled();
                    }
                }
            }

            // 1px bottom border.
            Rectangle {
                y: parent.height - 1px;
                height: 1px;
                background: Theme.border;
            }
        }

        // ----- Body: two panes (HATEOAS browse | REPL prompt) -------
        Rectangle {
            background: Theme.surface;
            vertical-stretch: 1;

            HorizontalLayout {
                padding: Theme.spacing-lg;
                spacing: Theme.spacing-lg;

                // ===== LEFT PANE: HATEOAS browse ====================
                // Same three-pane shape HateoasBrowser shipped, but
                // collapsed into a fixed-width column so the right
                // pane (REPL) gets the rest of the surface.
                Rectangle {
                    width: 520px;

                    HorizontalLayout {
                        spacing: Theme.spacing-md;

                        // ---- Pane 1a: Resources sidebar ------------
                        Rectangle {
                            width: 160px;
                            Card {
                                title: "Resources";
                                if root.resources.length == 0 : Text {
                                    text: "(no resources)";
                                    color: Theme.text-muted;
                                    font-family: Theme.type-body-sm.family;
                                    font-size: Theme.type-body-sm.size;
                                }
                                if root.resources.length > 0 : List {
                                    items: root.resources;
                                    selected-index: root.selected-resource-index;
                                    item-clicked(idx, value) => {
                                        root.resource-selected(idx);
                                    }
                                }
                            }
                        }

                        // ---- Pane 1b: Instance list ----------------
                        Rectangle {
                            horizontal-stretch: 1;
                            Card {
                                title: root.selected-resource-index >= 0
                                    ? "Instances"
                                    : "Pick a resource";
                                if root.selected-resource-index < 0 : Text {
                                    text: "Click a resource to list its instances.";
                                    color: Theme.text-muted;
                                    font-family: Theme.type-body.family;
                                    font-size: Theme.type-body.size;
                                    wrap: word-wrap;
                                }
                                if root.selected-resource-index >= 0
                                   && root.instances.length == 0 : Text {
                                    text: "(no facts yet)";
                                    color: Theme.text-muted;
                                    font-family: Theme.type-body-sm.family;
                                    font-size: Theme.type-body-sm.size;
                                }
                                if root.selected-resource-index >= 0
                                   && root.instances.length > 0 : List {
                                    items: root.instances;
                                    selected-index: root.selected-instance-index;
                                    item-clicked(idx, value) => {
                                        root.instance-selected(idx);
                                    }
                                }
                            }
                        }

                        // ---- Pane 1c: Detail panel -----------------
                        Rectangle {
                            width: 200px;
                            Card {
                                title: "Detail";
                                if root.detail-lines.length == 0 : Text {
                                    text: "Click an instance.";
                                    color: Theme.text-muted;
                                    font-family: Theme.type-body.family;
                                    font-size: Theme.type-body.size;
                                    wrap: word-wrap;
                                }
                                for line[idx] in root.detail-lines : Text {
                                    text: line;
                                    color: Theme.text-primary;
                                    font-family: Theme.type-code.family;
                                    font-weight: Theme.type-code.weight;
                                    font-size: Theme.type-code.size;
                                    wrap: word-wrap;
                                }
                            }
                        }
                    }
                }

                // ===== RIGHT PANE: typed surface + REPL =============
                // Cell-as-screen rendering (#511, EPIC #496): the
                // top portion is the typed surface for the current
                // cell (rendered through the Component selected via
                // the #492 selection rules); the middle is the REPL
                // scrollback; the bottom is the prompt input. The
                // typed surface IS the cell's projection through
                // its Component — it's what makes "every screen IS
                // a cell" visible to the user.
                Rectangle {
                    horizontal-stretch: 1;

                    VerticalLayout {
                        spacing: Theme.spacing-md;

                        // ---- Typed surface (cell-as-screen) -------
                        Rectangle {
                            min-height: 200px;
                            vertical-stretch: 1;
                            Card {
                                // Header: cell label, with the
                                // selected Component triple appended
                                // when a Component matched. When the
                                // selection missed (component string
                                // empty) the header just shows the
                                // cell label — the field list below
                                // is the generic key-value fallback.
                                title: root.current-cell-component == ""
                                    ? root.current-cell-name
                                    : root.current-cell-name + "  ·  "
                                      + root.current-cell-component
                                      + " (" + root.current-cell-toolkit
                                      + " / " + root.current-cell-symbol + ")";

                                // Empty-state hint when the cell
                                // has no projected fields at all
                                // (e.g. a phi cell). The Rust side
                                // populates a single placeholder
                                // line in that case so this branch
                                // is rare.
                                if root.current-cell-fields.length == 0 : Text {
                                    text: "(no projected fields)";
                                    color: Theme.text-muted;
                                    font-family: Theme.type-body-sm.family;
                                    font-size: Theme.type-body-sm.size;
                                    wrap: word-wrap;
                                }

                                // Generic key-value rendering. The
                                // "card" view of an Instance, the
                                // "list" view of a Noun, the raw
                                // "fact-cell" view — they all reduce
                                // to a list of lines on the kernel
                                // foundation slice. Future commits
                                // can swap this for dynamically-
                                // instantiated Slint sub-components
                                // once a runtime component loader
                                // exists.
                                for line in root.current-cell-fields : Text {
                                    text: line;
                                    color: Theme.text-primary;
                                    font-family: Theme.type-code.family;
                                    font-weight: Theme.type-code.weight;
                                    font-size: Theme.type-code.size;
                                    wrap: word-wrap;
                                }
                            }
                        }

                        // ---- Navigation targets (HATEOAS) ----------
                        // Navigation actions as cells (#512, EPIC #496).
                        // Every screen exposes its own catalogue of
                        // legal next moves derived from the FT graph
                        // (roles → joinable cells, derivations →
                        // consumed/produced cells, SM → next-state).
                        // Each row is one clickable affordance —
                        // clicks jump the current cell to the chosen
                        // target.
                        Rectangle {
                            min-height: 80px;
                            Card {
                                title: "Navigate";
                                if root.navigation-targets.length == 0 : Text {
                                    text: "(no navigation targets — this cell is a leaf)";
                                    color: Theme.text-muted;
                                    font-family: Theme.type-body-sm.family;
                                    font-size: Theme.type-body-sm.size;
                                    wrap: word-wrap;
                                }
                                if root.navigation-targets.length > 0 : List {
                                    items: root.navigation-targets;
                                    item-clicked(idx, value) => {
                                        root.navigation-target-selected(idx);
                                    }
                                }
                            }
                        }

                        // ---- Scrollback panel ----------------------
                        Rectangle {
                            min-height: 120px;
                            vertical-stretch: 1;
                            Card {
                                title: "REPL";
                                scroll := Flickable {
                                    // Coarse 20px per line — matches
                                    // Repl.slint's original estimate
                                    // (Theme.type-code.line-height).
                                    viewport-height: root.scrollback.length * 20px;

                                    VerticalLayout {
                                        spacing: 0px;

                                        if root.scrollback.length == 0 : Text {
                                            text: "(scrollback empty — type a command and press Enter)";
                                            color: Theme.text-muted;
                                            font-family: Theme.type-body-sm.family;
                                            font-size: Theme.type-body-sm.size;
                                        }

                                        for line in root.scrollback : Text {
                                            text: line;
                                            color: Theme.text-primary;
                                            font-family: Theme.type-code.family;
                                            font-weight: Theme.type-code.weight;
                                            font-size: Theme.type-code.size;
                                            wrap: word-wrap;
                                        }
                                    }
                                }
                            }
                        }

                        // ---- Input row -----------------------------
                        // Same shape as Repl.slint's input frame.
                        input-frame := Rectangle {
                            background: Theme.neutral-100;
                            border-color: input.has-focus ? Theme.accent : Theme.border;
                            border-width: 1px;
                            border-radius: 6px;
                            min-height: 36px;

                            animate border-color { duration: Theme.motion-fast; easing: ease-in-out; }

                            HorizontalLayout {
                                padding-left: Theme.spacing-md;
                                padding-right: Theme.spacing-md;
                                padding-top: Theme.spacing-sm;
                                padding-bottom: Theme.spacing-sm;
                                spacing: Theme.spacing-sm;

                                Text {
                                    text: root.prompt;
                                    color: Theme.accent;
                                    font-family: Theme.type-code.family;
                                    font-weight: Theme.type-code.weight;
                                    font-size: Theme.type-code.size;
                                    vertical-alignment: center;
                                }

                                input := TextInput {
                                    text <=> root.current-input;
                                    color: Theme.text-primary;
                                    font-family: Theme.type-code.family;
                                    font-weight: Theme.type-code.weight;
                                    font-size: Theme.type-code.size;
                                    single-line: true;

                                    accepted => {
                                        root.submit(self.text);
                                    }

                                    key-pressed(event) => {
                                        if (event.text == Key.UpArrow) {
                                            root.history-prev();
                                            return accept;
                                        } else if (event.text == Key.DownArrow) {
                                            root.history-next();
                                            return accept;
                                        } else if (event.modifiers.control && event.text == "l") {
                                            root.clear();
                                            return accept;
                                        }
                                        return reject;
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }

        // ----- Status footer ----------------------------------------
        Rectangle {
            background: Theme.neutral-100;
            min-height: 28px;

            // 1px top border.
            Rectangle {
                y: 0;
                height: 1px;
                background: Theme.border;
            }

            HorizontalLayout {
                padding-left: Theme.spacing-lg;
                padding-right: Theme.spacing-lg;
                padding-top: Theme.spacing-xs;
                padding-bottom: Theme.spacing-xs;

                Text {
                    text: root.status-text;
                    color: Theme.text-muted;
                    font-family: Theme.type-caption.family;
                    font-weight: Theme.type-caption.weight;
                    font-size: Theme.type-caption.size;
                    vertical-alignment: center;
                }
            }
        }
    }
}
