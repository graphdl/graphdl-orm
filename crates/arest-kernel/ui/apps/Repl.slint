// crates/arest-kernel/ui/apps/Repl.slint
//
// AREST kernel — second Slint app: REPL toolkit (#430 Track TTT).
//
// Mirrors Track SSS's #429 HateoasBrowser shape: a `Window`-derived
// component that consumes Track MMM's #436 design system (Theme,
// Card, Button) plus the existing `crate::repl` dispatch table via
// `crate::ui_apps::repl`. The Rust glue keeps a `Vec<String>`
// scrollback + a `Vec<String>` history; the Slint side renders
// scrollback above an input row and emits four callbacks
// (`submit`, `clear`, `history-prev`, `history-next`).
//
// Multi-entry pattern: this file is NOT the `slint::compile_with_
// config` entry — that is `HateoasBrowser.slint` (#429 / SSS,
// build.rs L222). HateoasBrowser.slint imports `Repl` from this file
// and re-exports it, so the slint compiler walks the import graph
// and emits both `HateoasBrowser` and `Repl` Rust structs into the
// single generated file consumed by `slint::include_modules!()` in
// `arch/uefi/slint_backend.rs` — same trick that keeps `AppShell`
// reachable through HateoasBrowser.slint's re-exports.
//
// Layout:
//   * Top bar (mirrors HateoasBrowser): title + theme toggle.
//   * Scrollback Card: a `Flickable` with a `VerticalLayout` of
//     monospace `Text` lines (`Theme.type-code` — JetBrains Mono).
//     New lines push the viewport-y to the bottom so the latest
//     output stays visible. Clip is on so over-tall content doesn't
//     spill into the input row.
//   * Input row: a prompt prefix (`Theme.type-code` "arest> ") + a
//     `TextInput` with `key-pressed` intercepting Up/Down/Ctrl+L.
//
// Up / Down walk the command history (Rust glue rotates an index +
// rewrites `current-input`). Ctrl+L clears the scrollback. Enter is
// `accepted` — Slint's TextInput single-line mode emits this when
// the user presses Return — and triggers the `submit` callback.

import { AppShell, Theme, ThemeMode } from "../AppShell.slint";
import { Button, ButtonVariant } from "../components/Button.slint";
import { Card } from "../components/Card.slint";

// Re-exports so HateoasBrowser.slint (the slint-build entry) can pull
// AppShell + Theme transitively through us when this file is the
// barrel. We don't need them here, but having the names in scope
// matches the pattern HateoasBrowser uses for AppShell — no harm,
// makes the import surface symmetric.

export component Repl inherits Window {
    // ---- Inputs (driven by the Rust glue) -------------------------

    // Each entry is one line of scrollback: previous prompts + the
    // responses they produced. The Rust glue caps the model at ~1000
    // entries (oldest dropped) so memory usage stays bounded across
    // long sessions.
    in property <[string]> scrollback;

    // The prompt prefix shown at the start of the input row. Defaults
    // to `arest> ` to match the BIOS-era `crate::repl::PROMPT`. Rust
    // can rebind it for sub-modes (e.g. `arest? ` while a multi-line
    // input is in progress, future work).
    in property <string> prompt: "arest> ";

    // Two-way binding to the live TextInput contents. Up/Down (history
    // walk) updates this from the Rust side; the user's keystrokes
    // update it from the Slint side. The `submit` callback reads the
    // final value before clearing.
    in-out property <string> current-input;

    // ---- Callbacks (Rust glue mutates state, then re-pushes models) -

    // Enter pressed in the input row. Argument is the just-submitted
    // line (= `current-input` at the moment of submit). Rust glue:
    //   1. Pushes `prompt + line` to scrollback.
    //   2. Calls `crate::repl::evaluate_line(&line)` for the response.
    //   3. Pushes the response (split on `\n`) to scrollback.
    //   4. Caps scrollback at 1000 lines.
    //   5. Pushes the line into command history.
    //   6. Resets `current-input` to "".
    callback submit(string);

    // Ctrl+L pressed in the input row. Rust glue clears the scrollback
    // model — input row contents are preserved.
    callback clear();

    // Up arrow pressed in the input row. Rust glue walks history one
    // step into the past and rewrites `current-input` to that entry.
    // No-op when history is empty or already at the oldest entry.
    callback history-prev();

    // Down arrow pressed in the input row. Walks history one step
    // toward the present; off the end, restores the in-progress edit
    // (Rust glue keeps a snapshot of the unsubmitted text for that).
    callback history-next();

    // Theme toggle, surfaced through this window's top bar so the user
    // can flip dark/light from inside the REPL. Mirrors HateoasBrowser
    // — the actual mode flip happens in `Theme.toggle-mode()`; this
    // callback is the host's hook for persisting the choice later.
    callback theme-toggled();

    title: "AREST — REPL";
    background: Theme.surface;
    default-font-family: Theme.type-body.family;
    default-font-size: Theme.type-body.size;
    preferred-width: 1024px;
    preferred-height: 720px;
    forward-focus: input;

    VerticalLayout {
        spacing: 0px;

        // ----- Top bar: title + theme toggle ------------------------
        // Mirrors HateoasBrowser's top bar styling so the two apps
        // feel continuous; we don't embed AppShell here because
        // AppShell's content slot uses a fixed VerticalLayout padding
        // that would compete with the REPL's tight scrollback +
        // input two-region body. Sharing the tokens (neutral-100,
        // border, type-h2, spacing-lg) preserves the visual continuity.
        Rectangle {
            background: Theme.neutral-100;
            min-height: 56px;

            HorizontalLayout {
                padding-left: Theme.spacing-lg;
                padding-right: Theme.spacing-lg;
                padding-top: Theme.spacing-md;
                padding-bottom: Theme.spacing-md;
                spacing: Theme.spacing-md;
                alignment: space-between;

                Text {
                    text: "REPL";
                    color: Theme.text-primary;
                    font-family: Theme.type-h2.family;
                    font-weight: Theme.type-h2.weight;
                    font-size: Theme.type-h2.size;
                    vertical-alignment: center;
                }

                Button {
                    text: Theme.mode == ThemeMode.dark ? "Light" : "Dark";
                    variant: ButtonVariant.ghost;
                    clicked => {
                        Theme.toggle-mode();
                        root.theme-toggled();
                    }
                }
            }

            // 1px bottom border.
            Rectangle {
                y: parent.height - 1px;
                height: 1px;
                background: Theme.border;
            }
        }

        // ----- Body: scrollback (top, fills) + input (bottom) -------
        Rectangle {
            background: Theme.surface;
            vertical-stretch: 1;

            VerticalLayout {
                padding: Theme.spacing-lg;
                spacing: Theme.spacing-md;

                // ---- Scrollback panel ----------------------------------
                // Card-wrapped Flickable. We compute viewport-height as
                // the sum of one line-height per entry so the Flickable
                // knows when scrolling is needed; on each model update
                // the Rust glue clamps `viewport-y` so the latest entry
                // stays in view (the `changed scrollback => { ... }`
                // handler below).
                Rectangle {
                    vertical-stretch: 1;
                    Card {
                        title: "";
                        // The actual scroll surface — Flickable clips
                        // the inner VerticalLayout to its own bounds
                        // and lets the user drag/wheel through.
                        scroll := Flickable {
                            // Estimated viewport height: 20px per entry
                            // (Theme.type-code.line-height). This is
                            // a coarse approximation — exact would
                            // require a Slint pass to query rendered
                            // child heights, which we don't need given
                            // every line is the same monospace size.
                            viewport-height: root.scrollback.length * 20px;

                            VerticalLayout {
                                spacing: 0px;

                                // Empty-state hint when no commands
                                // have been entered yet. Replaces the
                                // typical "welcome banner" the BIOS
                                // REPL emits at boot — that banner is
                                // injected by the Rust glue's
                                // `BrowserState::new` equivalent so
                                // the empty-state vanishes after the
                                // first frame.
                                if root.scrollback.length == 0 : Text {
                                    text: "(scrollback empty — type a command and press Enter)";
                                    color: Theme.text-muted;
                                    font-family: Theme.type-body-sm.family;
                                    font-size: Theme.type-body-sm.size;
                                }

                                for line in root.scrollback : Text {
                                    text: line;
                                    color: Theme.text-primary;
                                    font-family: Theme.type-code.family;
                                    font-weight: Theme.type-code.weight;
                                    font-size: Theme.type-code.size;
                                    wrap: word-wrap;
                                }
                            }
                        }
                    }
                }

                // ---- Input row -----------------------------------------
                // Prompt text + TextInput inside a bordered Rectangle.
                // We compose this directly here (instead of using the
                // shared `Input.slint` component from MMM) because
                // we need the `key-pressed` intercept on the TextInput
                // for Up/Down/Ctrl+L history navigation, which the
                // shared component doesn't expose. Styling matches
                // Input.slint: same border colors (`Theme.border`
                // resting, `Theme.accent` focused), same radius, same
                // padding tokens — a user looking at the app side by
                // side with the HATEOAS browser's search field
                // (future) won't notice the difference.
                input-frame := Rectangle {
                    background: Theme.neutral-100;
                    border-color: input.has-focus ? Theme.accent : Theme.border;
                    border-width: 1px;
                    border-radius: 6px;
                    min-height: 36px;

                    animate border-color { duration: Theme.motion-fast; easing: ease-in-out; }

                    HorizontalLayout {
                        padding-left: Theme.spacing-md;
                        padding-right: Theme.spacing-md;
                        padding-top: Theme.spacing-sm;
                        padding-bottom: Theme.spacing-sm;
                        spacing: Theme.spacing-sm;

                        Text {
                            text: root.prompt;
                            color: Theme.accent;
                            font-family: Theme.type-code.family;
                            font-weight: Theme.type-code.weight;
                            font-size: Theme.type-code.size;
                            vertical-alignment: center;
                        }

                        input := TextInput {
                            text <=> root.current-input;
                            color: Theme.text-primary;
                            font-family: Theme.type-code.family;
                            font-weight: Theme.type-code.weight;
                            font-size: Theme.type-code.size;
                            single-line: true;

                            // Enter -> submit. Slint's TextInput emits
                            // `accepted` for Return when single-line
                            // is set; the value passed to the callback
                            // is captured at the moment of accept, so
                            // even if the Rust glue clears
                            // `current-input` synchronously inside
                            // submit(), the argument remains intact.
                            accepted => {
                                root.submit(self.text);
                            }

                            // Up/Down/Ctrl+L intercept. Return
                            // `accept` to consume the keystroke
                            // (prevents TextInput from inserting the
                            // arrow into the buffer, which it
                            // wouldn't anyway, but the explicit
                            // accept makes the intent clear and
                            // stops focus traversal); `reject` for
                            // everything else so normal typing /
                            // Backspace / cursor keys all work.
                            key-pressed(event) => {
                                if (event.text == Key.UpArrow) {
                                    root.history-prev();
                                    return accept;
                                } else if (event.text == Key.DownArrow) {
                                    root.history-next();
                                    return accept;
                                } else if (event.modifiers.control && event.text == "l") {
                                    root.clear();
                                    return accept;
                                }
                                return reject;
                            }
                        }
                    }
                }
            }
        }

        // ----- Status footer ----------------------------------------
        Rectangle {
            background: Theme.neutral-100;
            min-height: 28px;

            // 1px top border.
            Rectangle {
                y: 0;
                height: 1px;
                background: Theme.border;
            }

            HorizontalLayout {
                padding-left: Theme.spacing-lg;
                padding-right: Theme.spacing-lg;
                padding-top: Theme.spacing-xs;
                padding-bottom: Theme.spacing-xs;

                Text {
                    text: root.scrollback.length + " lines • Up/Down history • Ctrl+L clear";
                    color: Theme.text-muted;
                    font-family: Theme.type-caption.family;
                    font-weight: Theme.type-caption.weight;
                    font-size: Theme.type-caption.size;
                    vertical-alignment: center;
                }
            }
        }
    }
}
