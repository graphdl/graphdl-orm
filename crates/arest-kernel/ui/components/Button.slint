// crates/arest-kernel/ui/components/Button.slint
//
// AREST kernel UI — Button base component (#436).
//
// Variants:
//   primary   — filled, accent background, surface text
//   secondary — outlined, surface background, primary text
//   ghost     — no background, accent text on hover-fill
//   danger    — filled, danger background, surface text
//
// All variants share the same typography (`Theme.type-button`),
// padding (`Theme.spacing-md` horizontal, `spacing-sm` vertical),
// and hover transition (`Theme.motion-fast` over the background).

import { Theme, ThemeMode } from "../theme.slint";

export enum ButtonVariant { primary, secondary, ghost, danger }

export component Button {
    in property <string> text;
    in property <ButtonVariant> variant: ButtonVariant.primary;
    in property <bool> enabled: true;
    callback clicked();

    // Computed surfaces. Each variant maps to {bg, text, border} that
    // depend on `Theme.*` and on the touch (`pressed`) / hover state
    // of the underlying TouchArea.
    property <color> bg:
        variant == ButtonVariant.primary  ? Theme.accent :
        variant == ButtonVariant.danger   ? Theme.danger :
        variant == ButtonVariant.secondary ? Theme.surface :
        /* ghost */                         transparent;

    property <color> bg-hover:
        variant == ButtonVariant.primary  ? Theme.accent.darker(0.08) :
        variant == ButtonVariant.danger   ? Theme.danger.darker(0.08) :
        variant == ButtonVariant.secondary ? Theme.neutral-200 :
        /* ghost */                         Theme.neutral-200;

    property <color> fg:
        variant == ButtonVariant.primary  ? Theme.surface :
        variant == ButtonVariant.danger   ? Theme.surface :
        variant == ButtonVariant.secondary ? Theme.text-primary :
        /* ghost */                         Theme.accent;

    property <color> stroke:
        variant == ButtonVariant.secondary ? Theme.border : transparent;

    min-height: 36px;

    states [
        disabled when !root.enabled : {
            opacity: 0.5;
        }
        hovered when touch.has-hover && root.enabled : {
            background.background: bg-hover;
        }
        pressed when touch.pressed && root.enabled : {
            background.background: bg-hover.darker(0.06);
        }
    ]

    background := Rectangle {
        background: bg;
        border-color: stroke;
        border-width: variant == ButtonVariant.secondary ? 1px : 0px;
        border-radius: 6px;

        animate background { duration: Theme.motion-fast; easing: ease-in-out; }

        HorizontalLayout {
            padding-left: Theme.spacing-md;
            padding-right: Theme.spacing-md;
            padding-top: Theme.spacing-sm;
            padding-bottom: Theme.spacing-sm;
            spacing: Theme.spacing-sm;
            alignment: center;

            Text {
                text: root.text;
                color: fg;
                font-family: Theme.type-button.family;
                font-weight: Theme.type-button.weight;
                font-size: Theme.type-button.size;
                vertical-alignment: center;
                horizontal-alignment: center;
            }
        }
    }

    touch := TouchArea {
        enabled: root.enabled;
        clicked => { root.clicked(); }
        mouse-cursor: root.enabled ? MouseCursor.pointer : MouseCursor.not-allowed;
    }

    animate opacity { duration: Theme.motion-fast; easing: ease-in-out; }
}
