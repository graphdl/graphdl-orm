#
# AREST minimal busybox config (#525, Track WWWWW)
#
# Selects ONLY the six smallest-useful applets:
#   ls, cat, echo, wc, head, tail
#
# Every other applet is disabled (`# CONFIG_<APPLET> is not set`)
# to keep the resulting static binary as small as possible. This is
# the tier-1 slice — a future track (#527 interactive shell session)
# can flip on `ash` and friends.
#
# Build options:
#   - CONFIG_STATIC=y           — link statically against musl libc.a
#   - CONFIG_NOMMU=n            — assume MMU (we have one in the
#                                 ELF-loader sandbox)
#   - CONFIG_PIE=n              — no PIE (the AREST ELF loader does
#                                 not yet relocate ET_DYN images;
#                                 #472)
#   - CONFIG_BUSYBOX_EXEC_PATH="/bin/busybox" — no /proc in tier-1
#
# This file is consumed by `crates/arest-kernel/build.rs`'s
# `build_busybox` pass, which bypasses busybox's Kconfig + Kbuild
# preprocessor and feeds the selected applet sources directly to
# `cc::Build`. The file lives in `busybox_config/` (sibling to
# `vendor/busybox/`) rather than under `vendor/busybox/configs/`
# so refreshing the upstream tree is a clean re-extract — same
# pattern DDDDD established for `musl_config/` in #524.
#

CONFIG_HAVE_DOT_CONFIG=y

#
# Busybox Settings
#

#
# General Configuration
#
# CONFIG_DESKTOP is not set
# CONFIG_EXTRA_COMPAT is not set
# CONFIG_INCLUDE_SUSv2 is not set
# CONFIG_USE_PORTABLE_CODE is not set
CONFIG_FEATURE_BUFFERS_USE_MALLOC=y
# CONFIG_FEATURE_BUFFERS_GO_ON_STACK is not set
# CONFIG_FEATURE_BUFFERS_GO_IN_BSS is not set
CONFIG_SHOW_USAGE=y
# CONFIG_FEATURE_VERBOSE_USAGE is not set
# CONFIG_FEATURE_COMPRESS_USAGE is not set
# CONFIG_FEATURE_INSTALLER is not set
# CONFIG_INSTALL_NO_USR is not set
# CONFIG_LOCALE_SUPPORT is not set
# CONFIG_UNICODE_SUPPORT is not set
# CONFIG_FEATURE_CHECK_UNICODE_IN_ENV is not set
# CONFIG_LONG_OPTS is not set
# CONFIG_FEATURE_DEVPTS is not set
# CONFIG_FEATURE_CLEAN_UP is not set
# CONFIG_FEATURE_PIDFILE is not set
CONFIG_PID_FILE_PATH=""
# CONFIG_FEATURE_SUID is not set
# CONFIG_FEATURE_SUID_CONFIG is not set
# CONFIG_FEATURE_SUID_CONFIG_QUIET is not set
CONFIG_SUID_CONFIG_FILE=""
# CONFIG_SELINUX is not set
# CONFIG_FEATURE_PREFER_APPLETS is not set
CONFIG_BUSYBOX_EXEC_PATH="/bin/busybox"
# CONFIG_FEATURE_SYSLOG is not set

#
# Build Options
#
CONFIG_STATIC=y
# CONFIG_PIE is not set
# CONFIG_NOMMU is not set
# CONFIG_BUILD_LIBBUSYBOX is not set
# CONFIG_FEATURE_INDIVIDUAL is not set
# CONFIG_FEATURE_SHARED_BUSYBOX is not set
CONFIG_LFS=y
CONFIG_CROSS_COMPILER_PREFIX=""
CONFIG_SYSROOT=""
CONFIG_EXTRA_CFLAGS=""
CONFIG_EXTRA_LDFLAGS=""
CONFIG_EXTRA_LDLIBS=""

#
# Debugging Options
#
# CONFIG_DEBUG is not set
# CONFIG_DEBUG_PESSIMIZE is not set
# CONFIG_UNIT_TEST is not set
# CONFIG_WERROR is not set
CONFIG_NO_DEBUG_LIB=y
# CONFIG_DMALLOC is not set
# CONFIG_EFENCE is not set

#
# Installation Options
#
# CONFIG_INSTALL_NO_USR is not set
CONFIG_INSTALL_APPLET_SYMLINKS=y
# CONFIG_INSTALL_APPLET_HARDLINKS is not set
# CONFIG_INSTALL_APPLET_SCRIPT_WRAPPERS is not set
# CONFIG_INSTALL_APPLET_DONT is not set
# CONFIG_INSTALL_SH_APPLET_SYMLINK is not set
# CONFIG_INSTALL_SH_APPLET_HARDLINK is not set
# CONFIG_INSTALL_SH_APPLET_SCRIPT_WRAPPER is not set
CONFIG_PREFIX="./_install"

#
# Busybox Library Tuning
#
# CONFIG_FEATURE_USE_SENDFILE is not set
CONFIG_FEATURE_COPYBUF_KB=4
# CONFIG_PASSWORD_MINLEN is not set
# CONFIG_MD5_SMALL is not set
# CONFIG_SHA3_SMALL is not set
# CONFIG_FEATURE_FAST_TOP is not set
# CONFIG_FEATURE_ETC_NETWORKS is not set
# CONFIG_FEATURE_ETC_SERVICES is not set
# CONFIG_FEATURE_USE_TERMIOS is not set
# CONFIG_FEATURE_EDITING is not set
# CONFIG_FEATURE_EDITING_MAX_LEN is not set
# CONFIG_FEATURE_EDITING_VI is not set
# CONFIG_FEATURE_EDITING_HISTORY is not set
# CONFIG_FEATURE_EDITING_SAVEHISTORY is not set
# CONFIG_FEATURE_EDITING_SAVE_ON_EXIT is not set
# CONFIG_FEATURE_REVERSE_SEARCH is not set
# CONFIG_FEATURE_TAB_COMPLETION is not set
# CONFIG_FEATURE_USERNAME_COMPLETION is not set
# CONFIG_FEATURE_EDITING_FANCY_PROMPT is not set
# CONFIG_FEATURE_EDITING_ASK_TERMINAL is not set
# CONFIG_FEATURE_NON_POSIX_CP is not set
# CONFIG_FEATURE_VERBOSE_CP_MESSAGE is not set
# CONFIG_MONOTONIC_SYSCALL is not set
# CONFIG_IOCTL_HEX2STR_ERROR is not set
# CONFIG_FEATURE_HWIB is not set
# CONFIG_FEATURE_SEAMLESS_XZ is not set
# CONFIG_FEATURE_SEAMLESS_LZMA is not set
# CONFIG_FEATURE_SEAMLESS_BZ2 is not set
# CONFIG_FEATURE_SEAMLESS_GZ is not set
# CONFIG_FEATURE_SEAMLESS_Z is not set
# CONFIG_FEATURE_RTMINMAX is not set

#
# ============================================================================
# Applets — only the SIX selected for tier-1 are enabled below.
# Every other applet is `# CONFIG_<APPLET> is not set`.
# ============================================================================
#

#
# Coreutils — the six chosen ones
#
CONFIG_CAT=y
CONFIG_FEATURE_CATN=y
# CONFIG_FEATURE_CATV is not set

CONFIG_ECHO=y
CONFIG_FEATURE_FANCY_ECHO=y

CONFIG_HEAD=y
CONFIG_FEATURE_FANCY_HEAD=y

CONFIG_LS=y
# CONFIG_FEATURE_LS_FILETYPES is not set
# CONFIG_FEATURE_LS_FOLLOWLINKS is not set
# CONFIG_FEATURE_LS_RECURSIVE is not set
CONFIG_FEATURE_LS_WIDTH=y
# CONFIG_FEATURE_LS_SORTFILES is not set
# CONFIG_FEATURE_LS_TIMESTAMPS is not set
# CONFIG_FEATURE_LS_USERNAME is not set
# CONFIG_FEATURE_LS_COLOR is not set
# CONFIG_FEATURE_LS_COLOR_IS_DEFAULT is not set

CONFIG_TAIL=y
CONFIG_FEATURE_FANCY_TAIL=y

CONFIG_WC=y
# CONFIG_FEATURE_WC_LARGE is not set

